# Copy this file to .env for local development (`npm run seed`, `vercel dev`).
# In production, set these as Environment Variables in the Vercel dashboard —
# do not commit a real .env file.

# Supabase Transaction Pooler connection string (port 6543).
# Settings → Database → Connection string → "Transaction pooler" tab.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# Admin login for the app itself (not a Supabase account).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Secret used to sign session tokens. Generate with: openssl rand -hex 32
AUTH_SECRET=
